# Локальный ChatList (.env) — GUI на вашем ПК.
#
# Вариант A (рекомендуется, если openrouter.ai недоступен локально):
# запросы идут через прокси на Vercel. Ключ OpenRouter — ТОЛЬКО на Vercel.
CHATLIST_PROXY_URL=https://your-project.vercel.app
CHATLIST_PROXY_SECRET=придумайте_общий_секрет

# Локальный клиент ходит на https://your-project.vercel.app/api
# Ключ OpenRouter задаётся только в Environment Variables на Vercel.

# Вариант B (прямой доступ к OpenRouter с вашего ПК):
# OPENROUTER_API_KEY=
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Прочие ключи (если нужны напрямую, без прокси):
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# GROQ_API_KEY=
# HUGGINGFACE_API_KEY=
